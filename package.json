{
  "name": "bpmn-react-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for @buildtovalue/* — a zero-dependency BPMN diagramming library for React with native versioning, governance and audit",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "lint": "eslint packages/*/src packages/*/tests packages/example/e2e scripts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "pnpm --filter @buildtovalue/example run e2e",
    "check:no-runtime-deps": "node scripts/check-no-runtime-deps.mjs",
    "check:no-key-generation": "node scripts/check-no-key-generation.mjs",
    "check:no-hardcoded-strings": "node scripts/check-no-hardcoded-strings.mjs",
    "check:docs-fresh": "node scripts/check-docs-fresh.mjs",
    "docs:api": "typedoc",
    "fetch:corpus": "node scripts/fetch-corpus.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.12.1",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  }
}
