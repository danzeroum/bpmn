{
  "name": "@buildtovalue/forms-react",
  "version": "1.0.0-next.0",
  "description": "Pure React renderer for @buildtovalue/forms schemas: controlled, headless-friendly, a11y-first. The SAME schema drives client rendering and server-side submission validation. Storybook stories ship with every component.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package.mjs dist/cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@buildtovalue/forms": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "keywords": [
    "forms",
    "react",
    "renderer",
    "bpmn"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/forms-react"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  }
}
