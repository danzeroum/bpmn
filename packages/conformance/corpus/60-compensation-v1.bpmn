    <bpmn:serviceTask id="Task_cancelHotel" name="Cancelar reserva" isForCompensation="true" />
    <bpmn:serviceTask id="Task_refundFlight" name="Estornar passagem" isForCompensation="true" />
    <bpmn:boundaryEvent id="Bnd_payErr" name="Cartão recusado" attachedToRef="Task_pay">
      <bpmn:errorEventDefinition id="Bnd_payErr_def" />
    </bpmn:boundaryEvent>
    <bpmn:intermediateThrowEvent id="Throw_comp" name="Reverter reservas">
      <bpmn:compensateEventDefinition id="Throw_comp_def" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="End_fail" name="Viagem cancelada" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_hotel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_hotel" targetRef="Task_flight" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_flight" targetRef="Task_pay" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_pay" targetRef="End_ok" />
    <bpmn:sequenceFlow id="Flow_err" sourceRef="Bnd_payErr" targetRef="Throw_comp" />
    <bpmn:sequenceFlow id="Flow_fail" sourceRef="Throw_comp" targetRef="End_fail" />
    <bpmn:association id="Assoc_hotel" sourceRef="Bnd_hotel" targetRef="Task_cancelHotel" />
    <bpmn:association id="Assoc_flight" sourceRef="Bnd_flight" targetRef="Task_refundFlight" />
