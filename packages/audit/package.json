{
  "name": "@buildtovalue/audit",
  "version": "1.1.0",
  "description": "Demonstrable integrity for bpmn-react governance: hash-chain ledger verification (verifyLedger), canonical promotion attestations (attestVersion) and XES export for process mining. Zero runtime dependencies.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package.mjs dist/cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@buildtovalue/core": "workspace:*",
    "@buildtovalue/identity": "workspace:*",
    "@buildtovalue/registry": "workspace:*"
  },
  "keywords": [
    "bpmn",
    "audit",
    "ledger",
    "attestation",
    "xes",
    "process-mining"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/audit"
  },
  "publishConfig": {
    "access": "public"
  }
}
