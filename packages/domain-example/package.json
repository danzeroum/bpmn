{
  "name": "@buildtovalue/domain-example",
  "version": "1.0.0",
  "description": "Example domain plugin for bpmn-react: squads, personas, gates, prompts, connectors and deliverables — a template for building your own domain vocabulary on top of the generic core.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./fixtures": {
      "types": "./dist/esm/fixtures.d.ts",
      "import": "./dist/esm/fixtures.js",
      "require": "./dist/cjs/fixtures.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package.mjs dist/cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@buildtovalue/core": "workspace:*",
    "@buildtovalue/react": "workspace:*"
  },
  "devDependencies": {
    "@buildtovalue/lint": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/domain-example"
  },
  "publishConfig": {
    "access": "public"
  }
}
