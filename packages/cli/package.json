{
  "name": "@bpmn-react/cli",
  "version": "1.0.0",
  "description": "Headless CLI for bpmn-react diagrams: validate, export (xml/json) and diff.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bpmn-react": "./dist/esm/bin.js"
  },
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bpmn-react/core": "workspace:*",
    "@bpmn-react/registry": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  }
}
