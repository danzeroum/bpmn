{
  "name": "@buildtovalue/studio",
  "version": "1.2.0-next.0",
  "description": "BuildToValue Studio (Handoff 6 S-4): the application layer for the no-screen personas — shell with hash navigation (no external router), the generic Biblioteca screen and the Revisão do Aprovador (engine-derived queue, real verification calls, immutable ledger decisions; approving never activates). Zero runtime dependencies beyond @buildtovalue/*.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package.mjs dist/cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@buildtovalue/adapters-bpmn": "workspace:*",
    "@buildtovalue/audit": "workspace:*",
    "@buildtovalue/conformance": "workspace:*",
    "@buildtovalue/copilot": "workspace:*",
    "@buildtovalue/core": "workspace:*",
    "@buildtovalue/identity": "workspace:*",
    "@buildtovalue/library": "workspace:*",
    "@buildtovalue/library-react": "workspace:*",
    "@buildtovalue/react": "workspace:*",
    "@buildtovalue/registry": "workspace:*",
    "@buildtovalue/soundness": "workspace:*"
  },
  "keywords": [
    "governance",
    "approval",
    "studio",
    "bpmn",
    "buildtovalue"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/studio"
  },
  "publishConfig": {
    "access": "public"
  }
}
