// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SVG markup snapshot > viewer canvas markup is stable for the reference diagram 1`] = `"<svg class="bpmnr-canvas" role="application" aria-label="BPMN diagram: Snapshot reference" data-zoom-band="full" width="100%" height="100%" viewBox="0 0 1200 800" style="display: block; background: var(--bpmnr-canvas-bg, #faf9f6); cursor: default; user-select: none;"><defs><filter id="bpmnr-shadow" x="-20%" y="-20%" width="140%" height="160%"><feDropShadow dx="0" dy="1" stdDeviation="2" style="flood-color: var(--bpmnr-shadow, #44403a); flood-opacity: 0.1;"></feDropShadow></filter><filter id="bpmnr-shadow-hover" x="-30%" y="-30%" width="160%" height="180%"><feDropShadow dx="0" dy="2" stdDeviation="4" style="flood-color: var(--bpmnr-shadow, #44403a); flood-opacity: 0.12;"></feDropShadow></filter><marker id="bpmnr-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="var(--bpmnr-stroke, #44403a)"></path></marker><marker id="bpmnr-arrow-muted" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="var(--bpmnr-text-muted, #6f675a)"></path></marker><marker id="bpmnr-arrow-selected" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="var(--bpmnr-selected, #1a6a54)"></path></marker><marker id="bpmnr-edge-filled" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="context-stroke"></path></marker><marker id="bpmnr-edge-open" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="9" markerHeight="9" orient="auto-start-reverse"><path d="M 1 1 L 9 5 L 1 9" fill="none" stroke="context-stroke" stroke-width="1.4"></path></marker><marker id="bpmnr-edge-disc" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><circle cx="5" cy="5" r="3.5" fill="context-stroke"></circle></marker><marker id="bpmnr-edge-chevron" viewBox="0 0 12 10" refX="10" refY="5" markerWidth="10" markerHeight="9" orient="auto-start-reverse"><path d="M 1 1 L 5 5 L 1 9 M 6 1 L 10 5 L 6 9" fill="none" stroke="context-stroke" stroke-width="1.4"></path></marker><pattern id="bpmnr-grid" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="1" fill="var(--bpmnr-grid-dot, #d8d3c8)"></circle></pattern><pattern id="bpmnr-closed-hatch" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="6" stroke="var(--btv-closed-hatch, #a49c8f)" stroke-width="1"></line></pattern></defs><rect x="-1200" y="-800" width="3600" height="2400" fill="url(#bpmnr-grid)" pointer-events="none"></rect><g data-layer="edges"><g data-edge-id="e1" role="link" aria-label="sequenceFlow connection" style="cursor: pointer;"><path d="M 76 98 C 136 98, 80 90, 140 90" fill="none" stroke="transparent" stroke-width="12"></path><path d="M 76 98 C 136 98, 80 90, 140 90" fill="none" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5" marker-end="url(#bpmnr-arrow)" pointer-events="none"></path></g><g data-edge-id="e2" role="link" aria-label="go" style="cursor: pointer;"><path d="M 260 90 C 320 90, 260 95, 320 95" fill="none" stroke="transparent" stroke-width="12"></path><path d="M 260 90 C 320 90, 260 95, 320 95" fill="none" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5" marker-end="url(#bpmnr-arrow)" pointer-events="none"></path><text class="bpmnr-edge-label" x="290" y="84.5" text-anchor="middle" font-size="11" fill="var(--bpmnr-text-muted, #6f675a)" paint-order="stroke" stroke="var(--bpmnr-canvas-bg, #faf9f6)" stroke-width="3" stroke-linejoin="round" pointer-events="none">go</text></g><g data-edge-id="e3" role="link" aria-label="sequenceFlow connection" style="cursor: pointer;"><path d="M 370 95 C 430 95, 380 98, 440 98" fill="none" stroke="transparent" stroke-width="12"></path><path d="M 370 95 C 430 95, 380 98, 440 98" fill="none" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5" marker-end="url(#bpmnr-arrow)" pointer-events="none"></path></g></g><g data-layer="nodes"><g transform="translate(40, 80)" data-node-id="start" data-node-type="startEvent" role="button" aria-label="startEvent: Start" opacity="1" style="cursor: default;"><g><g><circle cx="18" cy="18" r="18" fill="var(--bpmnr-fill-event, #eef4f0)" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5"></circle><text x="18" y="52" text-anchor="middle" font-size="11" fill="var(--bpmnr-text-muted, #6f675a)" font-family="inherit" pointer-events="none" paint-order="stroke" stroke="var(--bpmnr-canvas-bg, #faf9f6)" stroke-width="3" stroke-linejoin="round"><tspan x="18" dy="0">Start</tspan></text></g></g></g><g transform="translate(140, 60)" data-node-id="review" data-node-type="userTask" role="button" aria-label="userTask: Review" opacity="1" style="cursor: default;"><g><g data-node-shadow="true" filter="url(#bpmnr-shadow)"><g><rect width="120" height="60" rx="8" ry="8" fill="var(--bpmnr-fill-activity, #f8f7f4)" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5"></rect><g transform="translate(8, 6)" fill="none" stroke="var(--bpmnr-text-muted, #6f675a)" stroke-width="1.4"><circle cx="6" cy="4" r="3.2"></circle><path d="M 0.5 13 C 0.5 8.6 11.5 8.6 11.5 13"></path></g><text x="60" y="34" text-anchor="middle" font-size="12" fill="var(--bpmnr-text, #262220)" font-family="inherit" pointer-events="none"><tspan x="60" dy="0">Review</tspan></text></g></g></g></g><g transform="translate(320, 70)" data-node-id="gate" data-node-type="exclusiveGateway" role="button" aria-label="exclusiveGateway: OK?" opacity="1" style="cursor: default;"><g><g><polygon points="25,0 50,25 25,50 0,25" fill="var(--bpmnr-fill-gateway, #fdf4e3)" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5"></polygon><path d="M 17 17 L 33 33 M 33 17 L 17 33" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="2.5" stroke-linecap="round"></path><text x="25" y="66" text-anchor="middle" font-size="11" fill="var(--bpmnr-text-muted, #6f675a)" font-family="inherit" pointer-events="none" paint-order="stroke" stroke="var(--bpmnr-canvas-bg, #faf9f6)" stroke-width="3" stroke-linejoin="round"><tspan x="25" dy="0">OK?</tspan></text></g></g></g><g transform="translate(440, 80)" data-node-id="done" data-node-type="endEvent" role="button" aria-label="endEvent: Done" opacity="1" style="cursor: default;"><g><g><circle cx="18" cy="18" r="18" fill="var(--bpmnr-fill-event, #eef4f0)" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="3"></circle><circle cx="18" cy="18" r="13" fill="none" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1"></circle><text x="18" y="52" text-anchor="middle" font-size="11" fill="var(--bpmnr-text-muted, #6f675a)" font-family="inherit" pointer-events="none" paint-order="stroke" stroke="var(--bpmnr-canvas-bg, #faf9f6)" stroke-width="3" stroke-linejoin="round"><tspan x="18" dy="0">Done</tspan></text></g></g></g><g transform="translate(140, 200)" data-node-id="old" data-node-type="task" data-node-closed="true" role="button" aria-label="task: Legacy" opacity="0.75" style="cursor: default;"><g><g data-node-shadow="true" filter="url(#bpmnr-shadow)"><g><rect width="120" height="60" rx="8" ry="8" fill="var(--bpmnr-fill-activity, #f8f7f4)" stroke="var(--bpmnr-stroke, #44403a)" stroke-width="1.5"></rect><text x="60" y="34" text-anchor="middle" font-size="12" fill="var(--bpmnr-text, #262220)" font-family="inherit" pointer-events="none"><tspan x="60" dy="0">Legacy</tspan></text></g></g><g data-node-closed-hatch="true" pointer-events="none"><rect width="120" height="60" rx="10" fill="var(--btv-closed-fill, #f0eee9)" opacity="0.55"></rect><rect width="120" height="60" rx="10" fill="url(#bpmnr-closed-hatch)"></rect></g></g></g></g><g data-layer="overlay"></g></svg>"`;
