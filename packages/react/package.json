{
  "name": "@bpmn-react/react",
  "version": "1.0.0",
  "description": "React layer for bpmn-react: native SVG canvas, shapes, gestures, palette, inspector, minimap and diff view. Zero runtime dependencies (react/react-dom as peers).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package.mjs dist/cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@bpmn-react/core": "workspace:*",
    "@bpmn-react/simulation": "workspace:*"
  },
  "keywords": [
    "bpmn",
    "react",
    "svg",
    "diagram",
    "editor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}
