{
  "name": "@buildtovalue/react",
  "version": "1.2.0-next.0",
  "description": "React layer for bpmn-react: native SVG canvas, shapes, gestures, palette, inspector, minimap and diff view. Zero runtime dependencies (react/react-dom as peers).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./viewer": {
      "types": "./dist/esm/viewer.d.ts",
      "import": "./dist/esm/viewer.js",
      "require": "./dist/cjs/viewer.js"
    },
    "./worker": {
      "types": "./dist/esm/workers/worker.d.ts",
      "import": "./dist/esm/workers/worker.js",
      "require": "./dist/cjs/workers/worker.js"
    },
    "./styles.css": "./styles.css",
    "./simulation": {
      "types": "./dist/esm/simulation.d.ts",
      "import": "./dist/esm/simulation.js",
      "require": "./dist/cjs/simulation.js"
    },
    "./replay": {
      "types": "./dist/esm/replay.d.ts",
      "import": "./dist/esm/replay.js",
      "require": "./dist/cjs/replay.js"
    },
    "./agent": {
      "types": "./dist/esm/agent.d.ts",
      "import": "./dist/esm/agent.js",
      "require": "./dist/cjs/agent.js"
    },
    "./copilot": {
      "types": "./dist/esm/copilot.d.ts",
      "import": "./dist/esm/copilot.js",
      "require": "./dist/cjs/copilot.js"
    }
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package.mjs dist/cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@buildtovalue/agentflow": "workspace:*",
    "@buildtovalue/core": "workspace:*",
    "@buildtovalue/identity": "workspace:*",
    "@buildtovalue/lint": "workspace:*",
    "@buildtovalue/replay": "workspace:*",
    "@buildtovalue/simulation": "workspace:*",
    "@buildtovalue/copilot": "workspace:*"
  },
  "keywords": [
    "bpmn",
    "react",
    "svg",
    "diagram",
    "editor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danzeroum/bpmn.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}
